# =====================================================================
# Copy this file to  config/.env  and fill in your values.
# Used ONLY by the local Snowpipe lane (ingest/*.py). Never commit .env.
# =====================================================================

# --- Snowflake account ---
# ACCOUNT is the identifier in your URL: <orgname>-<account_name>
# e.g. https://abcd-xy12345.snowflakecomputing.com  ->  ABCD-XY12345
SNOWFLAKE_ACCOUNT=ORG-ACCOUNT
SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=RFAP_WH
SNOWFLAKE_DATABASE=RFAP_DB

# --- Key-pair auth for Snowpipe REST (see sql/03_snowpipe.sql) ---
# Absolute path to the UNENCRYPTED private key you generated.
SNOWFLAKE_PRIVATE_KEY_PATH=C:/Users/omkar/.snowflake/rsa_key.p8

# --- Snowpipe target ---
PIPE_FQN=RFAP_DB.BRONZE.RFAP_TXN_PIPE
TXN_STAGE=@RFAP_DB.BRONZE.TXN_STAGE

# --- Generator settings ---
TICKERS=AAPL,MSFT,NVDA,AMZN,TSLA,JPM,GS
TXN_PER_BATCH=500
FRAUD_RATE=0.02
BATCH_DIR=ingest/_batches
